# Azure Developer CLI Environment Variables
# Copy this file to .env and adjust values as needed for local development

# Azure Configuration - Set these if you have existing resources
KUSTO_CLUSTER=https://your-cluster.kusto.windows.net
KUSTO_DATABASE=SubscriptionDB
LOGIC_APP_URL=https://your-logic-app.azurewebsites.net/api/workflows/manual/triggers/When_a_HTTP_request_is_received/paths/invoke

# Application Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
DEMO_MODE=true

# Note: When deploying with azd, these can be set using:
# azd env set KUSTO_CLUSTER "https://your-cluster.kusto.windows.net"
# azd env set KUSTO_DATABASE "SubscriptionDB"
# azd env set LOGIC_APP_URL "https://your-logic-app-url"
# azd env set DEMO_MODE "false"